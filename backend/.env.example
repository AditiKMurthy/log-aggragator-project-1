# Database Connection URL (e.g., PostgreSQL local or Neon DB)
DATABASE_URL=postgresql://postgres:password@localhost:5432/doc_summarizer

# Redis / Celery URLs (e.g., local Redis or Upstash)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AI Provider API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
AI_API_KEY=your_alternative_ai_api_key_here

# Self-Hosted / Unified AI Engine Configurations (Optional)
AI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/
AI_MODEL=gemini-1.5-flash

# JWT Secret Key
SECRET_KEY=your_secret_key_here
