# Database Credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=doc_summarizer

# AI Provider API Keys (Replace these with your actual keys)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Self-Hosted / Unified AI Engine Configurations (Optional)
AI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/
AI_MODEL=gemini-1.5-flash
AI_API_KEY=your_unified_api_key_here

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# SMTP Email Configuration (Optional, fallback logs OTP directly to console if empty)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM=your_smtp_user_email@gmail.com

# JWT Secret Key
SECRET_KEY=your_secret_key_here
